@page "/"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Server
@namespace CivicPulse.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>Civic Pulse - Urban Complaint Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="~/css/app.css" rel="stylesheet" />
    <link href="~/css/auth.css" rel="stylesheet" />
    <link href="~/css/citizen-dashboard.css" rel="stylesheet" />
    <link href="~/css/submit-complaint.css" rel="stylesheet" />
    <link href="~/css/admin-dashboard.css" rel="stylesheet" />
    <link href="~/css/admin-complaints.css" rel="stylesheet" />
    <link href="~/css/sla-tracking.css" rel="stylesheet" />
    <link href="~/css/user-management.css" rel="stylesheet" />
    <link href="~/css/categories.css" rel="stylesheet" />
    <link href="~/css/my-complaints.css" rel="stylesheet" />
    <link href="~/css/audit-log.css" rel="stylesheet" />
    <link href="~/css/complaint-detail.css" rel="stylesheet" />
    <link href="~/css/notifications.css" rel="stylesheet" />
    <link href="~/css/feedback.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(CivicPulse.Web.App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/map.js"></script>
    <script src="~/js/charts.js"></script>
    <script src="~/js/interop.js"></script>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
