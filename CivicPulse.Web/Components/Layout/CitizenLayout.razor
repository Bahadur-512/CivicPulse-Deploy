@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationService NotificationService

<style>
    .citizen-shell { display:flex; height:100vh; overflow:hidden; background:#F7F8FA; }
    .citizen-sidebar { width:240px; min-width:240px; background:#0D2040 !important; display:flex; flex-direction:column; transition:width .25s ease,min-width .25s ease; overflow:hidden; z-index:100; }
    .citizen-sidebar.collapsed { width:64px; min-width:64px; }
    .citizen-brand { display:flex; align-items:center; gap:12px; padding:20px 16px 18px; border-bottom:1px solid rgba(255,255,255,0.06); white-space:nowrap; overflow:hidden; }
    .brand-logo { width:36px; height:36px; background:linear-gradient(135deg,#00897B,#00695C); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .brand-name { color:#fff; font-weight:800; font-size:1rem; display:block; }
    .brand-tagline { color:rgba(255,255,255,0.5); font-size:.65rem; display:block; text-transform:uppercase; letter-spacing:1px; }
    .citizen-nav { flex:1; padding:12px 10px; display:flex; flex-direction:column; gap:2px; overflow-y:auto; overflow-x:hidden; }
    .citizen-nav-section { font-size:.6rem; font-weight:700; color:rgba(255,255,255,0.35); text-transform:uppercase; letter-spacing:1.5px; padding:10px 8px 4px; white-space:nowrap; overflow:hidden; }
    .citizen-nav-item { display:flex; align-items:center; gap:11px; padding:10px 12px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:.855rem; font-weight:600; border-radius:10px; transition:all .15s ease; border:1px solid transparent; white-space:nowrap; overflow:hidden; }
    .citizen-nav-item:hover { background:rgba(255,255,255,0.06); color:#fff; }
    .citizen-nav-item.active { background:rgba(255,255,255,0.10); color:#fff; border-color:rgba(255,255,255,0.08); }
    .citizen-nav-item .nav-icon { width:18px; height:18px; flex-shrink:0; }
    .citizen-nav-cta { background:linear-gradient(135deg,#00897B,#00695C) !important; color:#fff !important; }
    .citizen-nav-cta:hover { opacity:0.9; }
    .nav-badge { margin-left:auto; background:#DC2626; color:#fff; font-size:.6rem; font-weight:800; padding:1px 6px; border-radius:10px; min-width:18px; text-align:center; }
    .citizen-sidebar-footer { padding:12px 10px; border-top:1px solid rgba(255,255,255,0.06); display:flex; align-items:center; justify-content:space-between; gap:8px; overflow:hidden; }
    .citizen-user-info { display:flex; align-items:center; gap:10px; overflow:hidden; flex:1; }
    .citizen-user-avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#00897B,#00695C); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.75rem; flex-shrink:0; }
    .citizen-user-name { display:block; color:rgba(255,255,255,0.85); font-size:.8rem; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:110px; }
    .citizen-user-role { display:block; color:rgba(255,255,255,0.4); font-size:.62rem; text-transform:uppercase; letter-spacing:.5px; }
    .citizen-collapse-btn { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.4); width:30px; height:30px; border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:.8rem; flex-shrink:0; transition:all .15s; }
    .citizen-collapse-btn:hover { background:rgba(255,255,255,0.1); color:#fff; }
    .citizen-topbar { height:60px; background:#fff; border-bottom:1px solid #E2E8F0; display:flex; align-items:center; padding:0 28px; gap:16px; position:sticky; top:0; z-index:50; }
    .topbar-title { font-weight:700; font-size:.95rem; color:#1A202C; }
    .topbar-actions { margin-left:auto; display:flex; align-items:center; gap:14px; }
    .citizen-user-menu { display:flex; align-items:center; gap:10px; }
    .citizen-avatar { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#00897B,#00695C); display:flex; align-items:center; justify-content:center; color:#fff; font-size:.75rem; }
    .citizen-name { font-size:.85rem; font-weight:700; color:#1A202C; }
    .citizen-role-badge { font-size:.62rem; font-weight:700; background:#EFF6FF; color:#2563EB; padding:1px 7px; border-radius:4px; text-transform:uppercase; letter-spacing:.5px; }
    .logout-btn { background:none; border:1px solid #E2E8F0; color:#94A3B8; cursor:pointer; padding:6px 10px; border-radius:8px; transition:all .15s; font-size:.9rem; }
    .logout-btn:hover { background:#FEF2F2; border-color:#FECACA; color:#DC2626; }
    .citizen-main { flex:1; display:flex; flex-direction:column; overflow:hidden; }
    .citizen-content { flex:1; overflow-y:auto; padding:28px 32px; background:#F7F8FA; }
    .mobile-menu-btn { display:none; background:none; border:none; font-size:1.4rem; cursor:pointer; color:#374151; }
    .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:150; backdrop-filter:blur(2px); }
    @@media (max-width:768px) {
        .citizen-sidebar { position:fixed; left:0; top:0; height:100%; z-index:200; transform:translateX(-100%); transition:transform .25s ease; }
        .citizen-sidebar.mobile-open { transform:translateX(0); }
        .sidebar-overlay { display:block; }
        .mobile-menu-btn { display:block; }
        .citizen-content { padding:16px; }
    }
</style>

<div class="citizen-shell">

    <aside class="citizen-sidebar @(collapsed ? "collapsed" : "") @(mobileOpen ? "mobile-open" : "")">

        <div class="citizen-brand">
            <div class="brand-logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" width="18" height="18">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                </svg>
            </div>
            @if (!collapsed)
            {
                <div>
                    <div class="brand-name">Civic Pulse</div>
                    <div class="brand-tagline">Citizen Portal</div>
                </div>
            }
        </div>

        <nav class="citizen-nav">
            @if (!collapsed) { <span class="citizen-nav-section">Overview</span> }

            <NavLink href="/citizen/dashboard" class="citizen-nav-item" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                @if (!collapsed) { <span>Dashboard</span> }
            </NavLink>

            @if (!collapsed) { <span class="citizen-nav-section">Complaints</span> }

            <NavLink href="/citizen/submit" class="citizen-nav-item citizen-nav-cta" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="16"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                @if (!collapsed) { <span>Submit Complaint</span> }
            </NavLink>

            <NavLink href="/citizen/complaints" class="citizen-nav-item" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                @if (!collapsed) { <span>My Complaints</span> }
            </NavLink>

            @if (!collapsed) { <span class="citizen-nav-section">Account</span> }

            <NavLink href="/citizen/notifications" class="citizen-nav-item" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 01-3.46 0"/>
                </svg>
                @if (!collapsed) { <span>Notifications</span> }
                @if (unreadCount > 0)
                {
                    <span class="nav-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                }
            </NavLink>
        </nav>

        <div class="citizen-sidebar-footer">
            @if (!collapsed)
            {
                <div class="citizen-user-info">
                    <div class="citizen-user-avatar">@(citizenName.Length > 0 ? citizenName[0].ToString().ToUpper() : "C")</div>
                    <div>
                        <span class="citizen-user-name">@citizenName</span>
                        <span class="citizen-user-role">Citizen</span>
                    </div>
                </div>
            }
            <button class="citizen-collapse-btn" @onclick="() => collapsed = !collapsed">
                @if (collapsed)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                }
            </button>
        </div>
    </aside>

    <div class="citizen-main">

        <header class="citizen-topbar">
            <button class="mobile-menu-btn" @onclick="() => mobileOpen = !mobileOpen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <span class="topbar-title">Civic Pulse</span>
            <div class="topbar-actions">
                <div class="citizen-user-menu">
                    <div class="citizen-avatar">@(citizenName.Length > 0 ? citizenName[0].ToString().ToUpper() : "C")</div>
                    <div>
                        <span class="citizen-name">@citizenName</span>
                        <span class="citizen-role-badge">Citizen</span>
                    </div>
                    <button class="logout-btn" @onclick="Logout" title="Logout">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                    </button>
                </div>
            </div>
        </header>

        <main class="citizen-content">
            @Body
        </main>
    </div>
</div>

@if (mobileOpen)
{
    <div class="sidebar-overlay" @onclick="() => mobileOpen = false"></div>
}

@code {
    private bool collapsed;
    private bool mobileOpen;
    private string citizenName = "Citizen";
    private int unreadCount;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        var role = user.FindFirst("role")?.Value ?? "";
        if (role != "Citizen")
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        citizenName = user.FindFirst("fullName")?.Value
                 ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                 ?? "Citizen";

        var userIdStr = user.FindFirst("userId")?.Value;
        if (int.TryParse(userIdStr, out var userId))
        {
            try { unreadCount = NotificationService.GetUnreadCount(userId); } catch { }
        }
    }

    private void Logout()
    {
        Navigation.NavigateTo("/api/auth/logout", true);
    }
}
