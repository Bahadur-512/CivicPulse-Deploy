@page "/forgot-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject IUserService UserService

<div class="auth-layout">
    <div class="auth-brand">
        <div class="auth-float"></div>
        <div class="auth-float"></div>
        <div class="auth-float"></div>
        <div class="auth-float"></div>

        <div class="auth-brand-icon"><i class="bi bi-building"></i></div>
        <div class="auth-brand-name">Civic Pulse</div>
        <div class="auth-brand-tagline">Your Voice. Your City.</div>

        <svg class="auth-svg" width="200" height="120" viewBox="0 0 200 120">
            <rect x="10" y="60" width="30" height="50" fill="white" rx="2"/>
            <rect x="50" y="40" width="30" height="70" fill="white" rx="2"/>
            <rect x="90" y="30" width="30" height="80" fill="white" rx="2"/>
            <rect x="130" y="50" width="30" height="60" fill="white" rx="2"/>
            <circle cx="25" cy="55" r="8" fill="white"/>
            <circle cx="65" cy="35" r="8" fill="white"/>
            <circle cx="105" cy="25" r="8" fill="white"/>
        </svg>

        <div class="auth-features">
            <div class="auth-feature-pill"><i class="bi bi-shield-check"></i> Report Issues Instantly</div>
            <div class="auth-feature-pill"><i class="bi bi-graph-up-arrow"></i> Real-Time Tracking</div>
            <div class="auth-feature-pill"><i class="bi bi-clock-history"></i> SLA-Based Resolution</div>
        </div>

    </div>

    <div class="auth-panel">
        <div class="auth-wrap" style="max-width:420px">

            @if (emailSent)
            {
                <div style="text-align:center;">
                    <div style="font-size:3.5rem;margin-bottom:16px;">📧</div>
                    <div class="auth-title">Check Your Email</div>
                    <div class="auth-subtitle">
                        If <strong>@email</strong> is registered, you will receive
                        a password reset link shortly.
                    </div>
                    <div style="text-align:left;background:#F8FAFC;border-radius:12px;padding:16px;margin:20px 0;display:flex;flex-direction:column;gap:12px;">
                        <div style="display:flex;align-items:center;gap:12px;font-size:0.875rem;color:#374151;">
                            <span style="width:24px;height:24px;border-radius:50%;background:#1B3A6B;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">1</span>
                            <span>Open your Gmail inbox</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;font-size:0.875rem;color:#374151;">
                            <span style="width:24px;height:24px;border-radius:50%;background:#1B3A6B;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">2</span>
                            <span>Click the "Reset My Password" button in the email</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;font-size:0.875rem;color:#374151;">
                            <span style="width:24px;height:24px;border-radius:50%;background:#1B3A6B;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0;">3</span>
                            <span>Enter your new password</span>
                        </div>
                    </div>
                    <p style="font-size:0.78rem;color:#9CA3AF;margin-bottom:20px;">⏰ The link expires in <strong>1 hour</strong></p>
                    <a href="/login" class="auth-btn auth-btn-primary" style="text-decoration:none;display:flex;justify-content:center;">Back to Sign In</a>
                </div>
            }
            else
            {
                <div class="auth-title">Forgot Password</div>
                <div class="auth-subtitle">Enter your email and we'll send you a reset link</div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="auth-alert auth-alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> @error</div>
                }

                <div class="auth-form-group">
                    <label class="auth-label" for="fpEmail">Email Address</label>
                    <div class="auth-input-wrapper">
                        <i class="bi bi-envelope auth-input-icon"></i>
                        <input id="fpEmail" type="email" placeholder="you@example.com" autocomplete="email" @bind="email" @bind:event="oninput" />
                    </div>
                </div>

                <button class="auth-btn auth-btn-primary @(isLoading ? "auth-btn-loading" : "")"
                        @onclick="HandleSubmit"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(email))">
                    <span class="auth-btn-text">
                        @if (isLoading) { <text>Sending...</text> }
                        else { <text>Send Reset Link</text> }
                    </span>
                </button>

                <div class="auth-demo">
                    <a href="/login" style="font-size:13px;font-weight:600;color:var(--cp-accent)"><i class="bi bi-arrow-left"></i> Back to Sign In</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private bool isLoading = false;
    private bool emailSent = false;
    private string error = "";

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;

        isLoading = true;
        error = "";

        try
        {
            await UserService.InitiatePasswordResetAsync(email.Trim());
            emailSent = true;
        }
        catch
        {
            error = "Something went wrong. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
