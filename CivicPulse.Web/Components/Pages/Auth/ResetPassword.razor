@page "/reset-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject IUserService UserService
@inject NavigationManager Navigation

<div class="auth-layout">
    <div class="auth-brand">
        <div class="auth-float"></div>
        <div class="auth-float"></div>
        <div class="auth-float"></div>
        <div class="auth-float"></div>

        <div class="auth-brand-icon"><i class="bi bi-building"></i></div>
        <div class="auth-brand-name">Civic Pulse</div>
        <div class="auth-brand-tagline">Your Voice. Your City.</div>

        <svg class="auth-svg" width="200" height="120" viewBox="0 0 200 120">
            <rect x="10" y="60" width="30" height="50" fill="white" rx="2"/>
            <rect x="50" y="40" width="30" height="70" fill="white" rx="2"/>
            <rect x="90" y="30" width="30" height="80" fill="white" rx="2"/>
            <rect x="130" y="50" width="30" height="60" fill="white" rx="2"/>
            <circle cx="25" cy="55" r="8" fill="white"/>
            <circle cx="65" cy="35" r="8" fill="white"/>
            <circle cx="105" cy="25" r="8" fill="white"/>
        </svg>

        <div class="auth-features">
            <div class="auth-feature-pill"><i class="bi bi-shield-check"></i> Report Issues Instantly</div>
            <div class="auth-feature-pill"><i class="bi bi-graph-up-arrow"></i> Real-Time Tracking</div>
            <div class="auth-feature-pill"><i class="bi bi-clock-history"></i> SLA-Based Resolution</div>
        </div>

    </div>

    <div class="auth-panel">
        <div class="auth-wrap" style="max-width:420px">

            @if (isValidating)
            {
                <div style="text-align:center;padding:40px;color:#94A3B8;">
                    <div style="margin:0 auto 12px;width:28px;height:28px;border:3px solid #E2E8F0;border-top-color:#1B3A6B;border-radius:50%;animation:authSpin .6s linear infinite;"></div>
                    Validating reset link...
                </div>
            }
            else if (!isTokenValid)
            {
                <div style="text-align:center;">
                    <div style="font-size:3rem;margin-bottom:12px;">❌</div>
                    <div class="auth-title">Link Expired</div>
                    <div class="auth-subtitle">
                        This password reset link has expired or is invalid.
                        Reset links are only valid for 1 hour.
                    </div>
                    <a href="/forgot-password" class="auth-btn auth-btn-primary" style="text-decoration:none;display:flex;justify-content:center;margin-top:20px;">Request New Reset Link</a>
                </div>
            }
            else if (resetSuccess)
            {
                <div style="text-align:center;">
                    <div style="font-size:3.5rem;margin-bottom:16px;">✅</div>
                    <div class="auth-title">Password Reset!</div>
                    <div class="auth-subtitle">
                        Your password has been updated successfully.
                        You can now sign in with your new password.
                    </div>
                    <a href="/login" class="auth-btn auth-btn-primary" style="text-decoration:none;display:flex;justify-content:center;margin-top:20px;">Sign In Now</a>
                </div>
            }
            else
            {
                <div class="auth-title">Reset Password</div>
                <div class="auth-subtitle">Enter your new password below</div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="auth-alert auth-alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> @error</div>
                }

                <div class="auth-form-group">
                    <label class="auth-label">New Password</label>
                    <div class="auth-input-wrapper">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input class="auth-input" type="@(showPwd ? "text" : "password")"
                               placeholder="Enter new password"
                               @bind="newPassword" @bind:event="oninput" />
                        <button type="button" class="auth-pw-toggle" @onclick="() => showPwd = !showPwd">
                            <i class="bi @(showPwd ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>

                <div class="auth-form-group">
                    <label class="auth-label">Confirm New Password</label>
                    <div class="auth-input-wrapper">
                        <i class="bi bi-shield-lock auth-input-icon"></i>
                        <input class="auth-input" type="@(showConfirm ? "text" : "password")"
                               placeholder="Repeat new password"
                               @bind="confirmPassword" @bind:event="oninput" />
                        <button type="button" class="auth-pw-toggle" @onclick="() => showConfirm = !showConfirm">
                            <i class="bi @(showConfirm ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword)
                    {
                        <span class="auth-field-error"><i class="bi bi-x-circle"></i> Passwords do not match</span>
                    }
                </div>

                <div class="auth-strength">
                    <div class="auth-strength-bar @GetStrength(0)"></div>
                    <div class="auth-strength-bar @GetStrength(1)"></div>
                    <div class="auth-strength-bar @GetStrength(2)"></div>
                    <div class="auth-strength-bar @GetStrength(3)"></div>
                </div>
                <div class="auth-strength-text @GetStrengthClass()">
                    @if (newPassword.Length > 0)
                    {
                        <text>@GetStrengthLabel()</text>
                    }
                </div>

                <button class="auth-btn auth-btn-primary @(isLoading ? "auth-btn-loading" : "")"
                        @onclick="HandleReset"
                        disabled="@(isLoading || !CanSubmit)">
                    <span class="auth-btn-text">
                        @if (isLoading) { <text>Updating...</text> }
                        else { <text>Update Password</text> }
                    </span>
                </button>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private bool showPwd = false;
    private bool showConfirm = false;
    private bool isLoading = false;
    private bool isValidating = true;
    private bool isTokenValid = false;
    private bool resetSuccess = false;
    private string error = "";

    private bool CanSubmit =>
        newPassword.Length >= 8 &&
        newPassword == confirmPassword;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            isTokenValid = false;
            isValidating = false;
            return;
        }

        isTokenValid = await UserService.ValidateResetTokenAsync(Token);
        isValidating = false;
    }

    private async Task HandleReset()
    {
        if (!CanSubmit || string.IsNullOrEmpty(Token)) return;

        isLoading = true;
        error = "";

        try
        {
            var success = await UserService.ResetPasswordByTokenAsync(Token, newPassword);
            if (success)
                resetSuccess = true;
            else
                error = "Reset failed — link may have expired. Please request a new one.";
        }
        catch
        {
            error = "Something went wrong. Please try again.";
        }
        finally { isLoading = false; }
    }

    private string GetStrength(int index)
    {
        if (newPassword.Length == 0) return "";
        var score = 0;
        if (newPassword.Length >= 8) score++;
        if (newPassword.Any(char.IsUpper)) score++;
        if (newPassword.Any(char.IsDigit)) score++;
        if (newPassword.Any(c => !char.IsLetterOrDigit(c))) score++;
        return index < score ? $"fill-{GetStrengthClass()}" : "";
    }

    private string GetStrengthClass() => newPassword.Length switch
    {
        0 => "",
        _ when newPassword.Any(c => !char.IsLetterOrDigit(c)) && newPassword.Any(char.IsUpper) && newPassword.Any(char.IsDigit) && newPassword.Length >= 8 => "strong",
        _ when newPassword.Any(char.IsUpper) && newPassword.Any(char.IsDigit) && newPassword.Length >= 8 => "good",
        _ when newPassword.Length >= 8 => "fair",
        _ => "weak"
    };

    private string GetStrengthLabel() => GetStrengthClass() switch
    {
        "weak" => "Weak", "fair" => "Fair", "good" => "Good", "strong" => "Strong", _ => ""
    };
}
